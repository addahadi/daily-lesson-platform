---
const platformName = "DevLevelUp";
const signupUrl = "https://devlevelup-dashboard.vercel.app/signup";

const columns = [
  {
    title: "Learn",
    links: [
      { label: "All courses", href: "/courses/frontend" },
      { label: "Frontend", href: "/courses/frontend" },
      { label: "Backend", href: "/courses/backend" },
      { label: "Data Science & AI", href: "/courses/data-science-ai" },
    ],
  },
  {
    title: "Platform",
    links: [
      { label: "Home", href: "/" },
      { label: "About", href: "/about" },
      { label: "Sign up", href: signupUrl },
      { label: "Log in", href: "https://devlevelup-dashboard.vercel.app/login" },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "Blog", href: "#" },
      { label: "Help center", href: "#" },
      { label: "Privacy policy", href: "#" },
      { label: "Terms of service", href: "#" },
    ],
  },
];
---

<footer class="relative overflow-hidden bg-ink text-slate-400">
  <!-- accent line + glow -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-orange/60 to-transparent"></div>
  <div class="pointer-events-none absolute -bottom-24 left-1/3 h-64 w-64 rounded-full bg-brand-orange/10 blur-3xl"></div>

  <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-5">
      <!-- Brand + CTA -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2">
          <img src="/logo.svg" width={32} height={32} alt="Logo" class="h-8 w-8" />
          <span class="font-display text-xl font-bold text-white">{platformName}</span>
        </a>
        <p class="mt-4 max-w-sm text-sm leading-relaxed">
          Learn to code with bite-sized lessons, interactive quizzes, and practical projects.
          Earn XP, build streaks, and level up your developer skills every day.
        </p>
        <a href={signupUrl} class="mt-6 inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-brand-orange to-brand-deep px-5 py-2.5 text-sm font-semibold text-white shadow-glow transition-transform hover:-translate-y-0.5">
          Start learning free
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>

      <!-- Link columns -->
      {columns.map((col) => (
        <div>
          <h3 class="font-mono text-xs font-semibold uppercase tracking-widest text-white">{col.title}</h3>
          <ul class="mt-4 space-y-3 text-sm">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="transition-colors hover:text-brand-glow">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="mt-14 flex flex-col items-center justify-between gap-6 border-t border-ink-line pt-8 sm:flex-row">
      <p class="text-sm text-slate-500">
        © {new Date().getFullYear()} {platformName}. All rights reserved.
      </p>

      <div class="flex items-center gap-3">
        <!-- Twitter / X -->
        <a href="#" aria-label="Twitter" class="grid h-9 w-9 place-items-center rounded-lg border border-ink-line text-slate-400 transition-all hover:border-brand-orange/40 hover:text-brand-glow">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M22.46 6c-.77.35-1.6.58-2.46.69a4.28 4.28 0 001.88-2.37 8.6 8.6 0 01-2.73 1.04A4.27 4.27 0 0015.5 4c-2.36 0-4.28 1.92-4.28 4.28 0 .34.04.67.11.99A12.1 12.1 0 013 5.15a4.28 4.28 0 001.32 5.71 4.25 4.25 0 01-1.94-.54v.05c0 2.05 1.46 3.76 3.39 4.15a4.3 4.3 0 01-1.93.07 4.28 4.28 0 004 2.97A8.57 8.57 0 012 19.54a12.07 12.07 0 006.54 1.92c7.85 0 12.15-6.5 12.15-12.15l-.01-.55A8.64 8.64 0 0024 5.46a8.48 8.48 0 01-2.54.7z"/></svg>
        </a>
        <!-- GitHub -->
        <a href="#" aria-label="GitHub" class="grid h-9 w-9 place-items-center rounded-lg border border-ink-line text-slate-400 transition-all hover:border-brand-orange/40 hover:text-brand-glow">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.58 2 12.26c0 4.5 2.87 8.32 6.84 9.67.5.1.68-.22.68-.48l-.01-1.7c-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.5-1.11-1.5-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.28 2.75 1.05a9.36 9.36 0 015 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.93-2.34 4.79-4.57 5.05.36.32.68.94.68 1.9l-.01 2.82c0 .27.18.59.69.48A10.03 10.03 0 0022 12.26C22 6.58 17.52 2 12 2z"/></svg>
        </a>
        <!-- LinkedIn -->
        <a href="#" aria-label="LinkedIn" class="grid h-9 w-9 place-items-center rounded-lg border border-ink-line text-slate-400 transition-all hover:border-brand-orange/40 hover:text-brand-glow">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M4.98 3.5a2.5 2.5 0 11-.02 5 2.5 2.5 0 01.02-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.3-.02-2.96-1.8-2.96-1.8 0-2.08 1.4-2.08 2.86V21H9z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
