---
import "../../global.css";
const { title = "DevLevelUp — Level up your dev skills, one lesson a day" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="DevLevelUp helps you grow as a developer through interactive lessons, quizzes, and hands-on projects. Track progress, earn XP, and level up your coding journey." />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="bg-cream font-sans text-ink antialiased">
    <slot />
  </body>
</html>
